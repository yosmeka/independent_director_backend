# Copy to .env and adjust. Never commit real secrets.

NODE_ENV=development
PORT=3000

# CORS — the Vite dev server origin
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://zemen:zemen@localhost:5432/zemen_director_portal
# In dev, auto-create schema from entities. Use migrations in prod.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT — generate strong random secrets for any non-local environment
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=7d

# OTP
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=4

# Email (SMTP). Defaults target the local Mailpit container (docker compose).
# View caught mail at http://localhost:8025. For production, point these at a real
# provider (SendGrid/SES/Postmark/Gmail) and set SMTP_USER/SMTP_PASS + SMTP_SECURE.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Zemen Bank <no-reply@zemen.test>

# Object storage (S3 / MinIO) — used by the documents module (later phase)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=zemen-documents
S3_ACCESS_KEY=zemen
S3_SECRET_KEY=zemen-secret
S3_FORCE_PATH_STYLE=true
